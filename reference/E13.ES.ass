Dialogue: 0,0:21:03.93,0:21:06.83,Dragon Ball 3,,0,0,0,,{\i1}Ven, fantasía{\i0}
Dialogue: 0,0:21:06.83,0:21:09.43,Dragon Ball 2,,0,0,0,, {\i1}Suki sa misuteri{\i0}
Dialogue: 0,0:21:06.83,0:21:09.43,Dragon Ball 3,,0,0,0,,{\i1}Me gusta el misterio{\i0}
Dialogue: 0,0:21:09.43,0:21:16.01,Dragon Ball 2,,0,0,0,, {\i1}Kimi no wakasa kakusanai de{\i0}
Dialogue: 0,0:21:09.43,0:21:16.01,Dragon Ball 3,,0,0,0,,{\i1}¡No escondas tu juventud!{\i0}
Dialogue: 0,0:21:16.01,0:21:19.01,Dragon Ball 2,,0,0,0,, {\i1}Fushigi shitakute{\i0}
Dialogue: 0,0:21:16.01,0:21:19.01,Dragon Ball 3,,0,0,0,,{\i1}Quiero hacer lo misterioso{\i0}
Dialogue: 0,0:21:19.01,0:21:21.51,Dragon Ball 2,,0,0,0,, {\i1}Boken shitakute{\i0}
Dialogue: 0,0:21:19.01,0:21:21.51,Dragon Ball 3,,0,0,0,,{\i1}Quiero perseguir la aventura{\i0}
Dialogue: 0,0:21:21.51,0:21:27.52,Dragon Ball 2,,0,0,0,, {\i1}Dare mo min'na uzu-uzu shite 'ru{\i0}
Dialogue: 0,0:21:21.51,0:21:27.52,Dragon Ball 3,,0,0,0,,{\i1}¡Todos están ansiosos por ir!{\i0}
Dialogue: 0,0:21:27.52,0:21:33.52,Dragon Ball 2,,0,0,0,, {\i1}Otona no furi shite akiramecha{\i0}
Dialogue: 0,0:21:27.52,0:21:33.52,Dragon Ball 3,,0,0,0,,{\i1}Si actúas como adulto y te rindes{\i0}
Dialogue: 0,0:21:33.52,0:21:39.70,Dragon Ball 2,,0,0,0,, {\i1}Kiseki no nazo nado tokenai yo{\i0}
Dialogue: 0,0:21:33.52,0:21:39.70,Dragon Ball 3,,0,0,0,,{\i1}¡Nunca desentrañarás el misterio
del milagro!{\i0}
Dialogue: 0,0:21:39.70,0:21:50.81,Dragon Ball 2,,0,0,10,, {\i1}Motto wairudo ni motto takumashiku
ikite goran{\i0}
Dialogue: 0,0:21:39.70,0:21:50.81,Dragon Ball 3,,0,0,0,,{\i1}Intenta vivir{\i0}\N{\i1}aun más\Nsalvaje y fuerte!{\i0}
