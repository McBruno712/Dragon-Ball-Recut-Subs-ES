Dialogue: 0,0:26:31.34,0:26:33.94,Dragon Ball 3,,0,0,0,,{\i1}Amo el misterio{\i0}
Dialogue: 0,0:26:33.94,0:26:40.51,Dragon Ball 2,,0,0,0,, {\i1}Kimi no wakasa kakusanai de{\i0}
Dialogue: 0,0:26:33.94,0:26:40.51,Dragon Ball 3,,0,0,0,,{\i1}¡No escondas tu juventud!{\i0}
Dialogue: 0,0:26:40.51,0:26:43.51,Dragon Ball 2,,0,0,0,, {\i1}Fushigi shitakute{\i0}
Dialogue: 0,0:26:40.51,0:26:43.51,Dragon Ball 3,,0,0,0,,{\i1}Queriendo hacer lo misterioso{\i0}
