Dialogue: 0,0:01:10.71,0:01:13.77,Dragon Ball 2,,0,0,0,, {\i1}Let's fly, fly, fly, daiboken{\i0}
Dialogue: 0,0:01:10.71,0:01:13.77,Dragon Ball 3,,0,0,0,,{\i1}Volemos, volemos, gran\naventura{\i0}
Dialogue: 0,0:01:14.28,0:01:21.42,Dragon Ball 2,,0,0,0,, {\i1}Fushigi na tabi ga hajimaru ze{\i0}
Dialogue: 0,0:01:14.28,0:01:21.42,Dragon Ball 3,,0,0,0,,{\i1}¡Nuestro extraño viaje comienza!{\i0}
Dialogue: 0,0:01:21.42,0:01:24.92,Dragon Ball 2,,0,0,0,,{\i1}Te ni irero! Doragon Booru{\i0}
Dialogue: 0,0:01:21.42,0:01:24.92,Dragon Ball 3,,0,0,0,,{\i1}¡En nuestras manos! ¡Las Esferas\Ndel Dragón!{\i0}
Dialogue: 0,0:01:24.92,0:01:28.12,Dragon Ball 2,,0,0,0,, {\i1}Sekai de itto tegowai chansu{\i0}
Dialogue: 0,0:01:24.92,0:01:28.12,Dragon Ball 3,,0,0,0,,{\i1}Una de las apuestas más\natrevidas del mundo{\i0}
Dialogue: 0,0:01:28.52,0:01:31.58,Dragon Ball 2,,0,0,0,,{\i1}Oikakero! Doragon Booru{\i0}
Dialogue: 0,0:01:28.52,0:01:31.58,Dragon Ball 3,,0,0,0,,{\i1}¡A perseguirlas! ¡Las Esferas\Ndel Dragón!{\i0}
Dialogue: 0,0:01:31.93,0:01:35.16,Dragon Ball 2,,0,0,0,, {\i1}Sekai de itto ikashita dorama{\i0}
Dialogue: 0,0:01:31.93,0:01:35.16,Dragon Ball 3,,0,0,0,,{\i1}Una de las historias más\nentretenidas del mundo{\i0}
Dialogue: 0,0:01:35.16,0:01:38.63,Dragon Ball 2,,0,0,0,, {\i1}Kono yo wa dekkai takarajima{\i0}
