Dialogue: 0,0:01:10.51,0:01:13.57,Dragon Ball 2,,0,0,0,, {\i1}Let's fly, fly, fly, daiboken{\i0}
Dialogue: 0,0:01:10.51,0:01:13.57,Dragon Ball 3,,0,0,0,,{\i1}Volemos, volemos, gran\naventura{\i0}
Dialogue: 0,0:01:14.08,0:01:21.22,Dragon Ball 2,,0,0,0,, {\i1}Fushigi na tabi ga hajimaru ze{\i0}
Dialogue: 0,0:01:14.08,0:01:21.22,Dragon Ball 3,,0,0,0,,{\i1}¡Nuestro extraño viaje comienza!{\i0}
Dialogue: 0,0:01:21.22,0:01:24.72,Dragon Ball 2,,0,0,0,,{\i1}Te ni irero! Doragon Booru{\i0}
Dialogue: 0,0:01:21.22,0:01:24.72,Dragon Ball 3,,0,0,0,,{\i1}¡En nuestras manos! ¡Las Esferas\Ndel Dragón!{\i0}
Dialogue: 0,0:01:24.72,0:01:27.92,Dragon Ball 2,,0,0,0,, {\i1}Sekai de itto tegowai chansu{\i0}
Dialogue: 0,0:01:24.72,0:01:27.92,Dragon Ball 3,,0,0,0,,{\i1}Una de las apuestas más\natrevidas del mundo{\i0}
Dialogue: 0,0:01:28.33,0:01:31.39,Dragon Ball 2,,0,0,0,,{\i1}Oikakero! Doragon Booru{\i0}
Dialogue: 0,0:01:28.33,0:01:31.39,Dragon Ball 3,,0,0,0,,{\i1}¡A perseguirlas! ¡Las Esferas\Ndel Dragón!{\i0}
Dialogue: 0,0:01:31.73,0:01:34.97,Dragon Ball 2,,0,0,0,, {\i1}Sekai de itto ikashita dorama{\i0}
Dialogue: 0,0:01:31.73,0:01:34.97,Dragon Ball 3,,0,0,0,,{\i1}Una de las historias más\nentretenidas del mundo{\i0}
Dialogue: 0,0:01:34.97,0:01:38.44,Dragon Ball 2,,0,0,0,, {\i1}Kono yo wa dekkai takarajima{\i0}
