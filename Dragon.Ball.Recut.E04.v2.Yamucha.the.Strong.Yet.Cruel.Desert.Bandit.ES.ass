Dialogue: 0,0:01:24.91,0:01:28.11,Dragon Ball 3,,0,0,0,,{\i1}Una de las apuestas más\nformidables del mundo{\i0}
Dialogue: 0,0:01:28.51,0:01:31.57,Dragon Ball 2,,0,0,0,,{\i1}Oikakero! Doragon Booru{\i0}
Dialogue: 0,0:01:28.51,0:01:31.57,Dragon Ball 3,,0,0,0,,{\i1}¡A perseguirlas! ¡Las Esferas\Ndel Dragón!{\i0}
Dialogue: 0,0:01:31.92,0:01:35.15,Dragon Ball 2,,0,0,0,, {\i1}Sekai de itto ikashita dorama{\i0}
Dialogue: 0,0:01:31.92,0:01:35.15,Dragon Ball 3,,0,0,0,,{\i1}Una de las historias más\nentretenidas del mundo{\i0}
Dialogue: 0,0:01:35.15,0:01:38.62,Dragon Ball 2,,0,0,0,, {\i1}Kono yo wa dekkai takarajima{\i0}
