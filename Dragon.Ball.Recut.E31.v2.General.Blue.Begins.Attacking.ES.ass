Dialogue: 0,0:24:24.19,0:24:26.69,Dragon Ball 3,,0,0,0,,{\i1}Queriendo perseguir la aventura{\i0}
Dialogue: 0,0:24:26.69,0:24:32.70,Dragon Ball 2,,0,0,0,, {\i1}Dare mo min'na uzu-uzu shite 'ru{\i0}
Dialogue: 0,0:24:26.69,0:24:32.70,Dragon Ball 3,,0,0,0,,{\i1}¡Todos están ansiosos por irse!{\i0}
Dialogue: 0,0:24:32.70,0:24:38.74,Dragon Ball 2,,0,0,0,, {\i1}Otona no furi shite akiramecha{\i0}
Dialogue: 0,0:24:32.70,0:24:38.74,Dragon Ball 3,,0,0,0,,{\i1}Si actúas como adulto y te rindes{\i0}
