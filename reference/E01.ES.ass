Dialogue: 0,0:01:24.72,0:01:27.91,Dragon Ball 3,,0,0,0,,{\i1}Una de las apuestas más\Natrevidas del mundo{\i0}
Dialogue: 0,0:01:28.31,0:01:31.37,Dragon Ball 2,,0,0,0,,{\i1}Oikakero! Doragon Booru{\i0}
Dialogue: 0,0:01:28.31,0:01:31.37,Dragon Ball 3,,0,0,0,,{\i1}¡A perseguirlas! ¡Las Esferas\Ndel Dragón!{\i0}
Dialogue: 0,0:01:31.72,0:01:34.95,Dragon Ball 2,,0,0,0,,{\i1}Sekai de itto ikashita dorama{\i0}
Dialogue: 0,0:01:31.72,0:01:34.95,Dragon Ball 3,,0,0,0,,{\i1}Una de las historias más\Nentretenidas del mundo{\i0}
Dialogue: 0,0:01:34.95,0:01:38.42,Dragon Ball 2,,0,0,0,,{\i1}Kono yo wa dekkai takarajima{\i0}
