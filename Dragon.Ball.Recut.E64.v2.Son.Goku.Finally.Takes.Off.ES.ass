Dialogue: 0,0:24:29.67,0:24:32.17,Dragon Ball 3,,0,0,0,,{\i1}Queriendo buscar la aventura{\i0}
Dialogue: 0,0:24:32.17,0:24:38.18,Dragon Ball 2,,0,0,0,, {\i1}Dare mo min'na uzu-uzu shite 'ru{\i0}
Dialogue: 0,0:24:32.17,0:24:38.18,Dragon Ball 3,,0,0,0,,{\i1}¡Todos están ansiosos por ir!{\i0}
Dialogue: 0,0:24:38.18,0:24:44.18,Dragon Ball 2,,0,0,0,, {\i1}Otona no furi shite akiramecha{\i0}
Dialogue: 0,0:24:38.18,0:24:44.18,Dragon Ball 3,,0,0,0,,{\i1}Si actúas como adulto y te rindes{\i0}
