Dialogue: 0,0:01:28.47,0:01:31.53,Dragon Ball 3,,0,0,0,,{\i1}¡A perseguirlas! ¡Las Esferas\Ndel Dragón!{\i0}
Dialogue: 0,0:01:31.87,0:01:35.10,Dragon Ball 2,,0,0,0,, {\i1}Sekai de itto ikashita dorama{\i0}
Dialogue: 0,0:01:31.87,0:01:35.10,Dragon Ball 3,,0,0,0,,{\i1}Una de las historias más\nentretenidas del mundo{\i0}
Dialogue: 0,0:01:35.11,0:01:38.57,Dragon Ball 2,,0,0,0,, {\i1}Kono yo wa dekkai takarajima{\i0}
