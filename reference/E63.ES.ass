Dialogue: 0,0:21:59.26,0:22:01.76,Dragon Ball 3,,0,0,0,,{\i1}Queriendo buscar la aventura{\i0}
Dialogue: 0,0:22:01.76,0:22:07.77,Dragon Ball 2,,0,0,0,, {\i1}Dare mo min'na uzu-uzu shite 'ru{\i0}
Dialogue: 0,0:22:01.76,0:22:07.77,Dragon Ball 3,,0,0,0,,{\i1}¡Todos están ansiosos por ir!{\i0}
