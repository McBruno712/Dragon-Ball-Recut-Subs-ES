Dialogue: 0,0:24:14.65,0:24:21.19,Dragon Ball 3,,0,0,0,,{\i1}¡No escondas tu juventud!{\i0}
Dialogue: 0,0:24:21.19,0:24:24.19,Dragon Ball 2,,0,0,0,, {\i1}Fushigi shitakute{\i0}
Dialogue: 0,0:24:21.19,0:24:24.19,Dragon Ball 3,,0,0,0,,{\i1}Queriendo hacer lo misterioso{\i0}
