Dialogue: 0,0:01:06.82,0:01:09.59,Dragon Ball 3,,0,0,5,,{\i1}Cruzando el cielo,{\i0}\N{\i1}superando las\Nmontañas{\i0}
Dialogue: 0,0:01:10.49,0:01:13.55,Dragon Ball 2,,0,0,0,,{\i1}Let's fly, fly, fly, daiboken{\i0}
Dialogue: 0,0:01:10.49,0:01:13.55,Dragon Ball 3,,0,0,0,,{\i1}Volemos, volemos, gran\Naventura{\i0}
Dialogue: 0,0:01:14.07,0:01:21.20,Dragon Ball 2,,0,0,0,,{\i1}Fushigi na tabi ga hajimaru ze{\i0}
Dialogue: 0,0:01:14.07,0:01:21.20,Dragon Ball 3,,0,0,0,,{\i1}¡Nuestro extraño viaje comienza!{\i0}
Dialogue: 0,0:01:21.21,0:01:24.71,Dragon Ball 2,,0,0,0,,{\i1}Te ni irero! Doragon Booru{\i0}
Dialogue: 0,0:01:21.21,0:01:24.71,Dragon Ball 3,,0,0,0,,{\i1}¡En nuestras manos! ¡Las Esferas\Ndel Dragón!{\i0}
